# Legal Document Comparator - Environment Configuration

# Groq Cloud API
# Get your API key from: https://console.groq.com
AI__Groq__ApiKey=YOUR_GROQ_API_KEY_HERE
AI__Groq__Model=llama-3.1-70b-versatile
AI__Groq__BaseUrl=https://api.groq.com/openai/v1

# Database
Database__Path=data/legal-comparator.db

# File Storage
Storage__Path=storage/documents

# JWT Configuration
JwtSettings__SecretKey=YourSecretKeyHere_AtLeast32CharactersLong_ForHS256Algorithm_ChangeInProduction
JwtSettings__Issuer=LegalDocumentComparator
JwtSettings__Audience=LegalDocumentComparatorUsers
JwtSettings__ExpirationHours=24

# CORS (Frontend URLs)
Cors__AllowedOrigins__0=http://localhost:5173
Cors__AllowedOrigins__1=http://localhost:3000

# Logging
Logging__LogLevel__Default=Information
Logging__LogLevel__Microsoft.AspNetCore=Warning
